
<h1 class="text-center mt-5">My lists</h1>

<div class="container py-5">

  <div class="row justify-content-center g-4 mb-5">
    <% if @lists.empty? %>
      <%= "Sorry you don't have any list yet" %>
    <% else %>
      <% @lists.each do |list| %>

          <div class="col-12 col-md-6 col-lg-4">

            <div class="card shadow-sm mb-3 p-3 text-white d-flex justify-content-center align-items-center text-center"
                  style="height: 300px;
                        background-size: cover;
                        background-position: center;
                        background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)),
                        url('<%= cl_image_path list.photo.key, height: 300, crop: :fill %>')">

  <h2 class="card-title mb-0">
    <%= link_to list.name, list_path(list), class: "text-white text-decoration-none" %>
  </h2>

</div>

        </div>
      <% end %>
    <% end %>

    <div class="text-center mt-4">
      <%= link_to "New list", new_list_path, class: "btn btn-custom  px-5 py-3" %>
    </div>

  </div>
</div>
