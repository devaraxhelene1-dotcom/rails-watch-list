
<h1 class="text-center mt-5">My lists</h1>

<div class="container mt-4">
  <div class="col-md-8 mx-auto">
    <% if @lists.empty? %>
      <%= "Sorry you don't have any list yet" %>
    <% else %>
      <% @lists.each do |list| %>
        <div class="card shadow-sm mb-3 p-3" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('<%= cl_image_path list.photo.key, height: 300, crop: :fill %>')">
          <h2 class="card-title mb-2">
            <%= link_to list.name, list_path(list), class: "text-decoration-none" %>
          </h2>
        </div>
      <% end %>
    <% end %>

    <div class="text-center mt-4">
      <%= link_to "New list", new_list_path, class: "btn btn-primary" %>
    </div>

  </div>
</div>
