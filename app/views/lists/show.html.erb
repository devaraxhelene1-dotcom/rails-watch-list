<div class="text-center text-white d-flex align-items-center justify-content-center shadow-sm mb-3"
    style="
      height: 350px;
      background-size: cover;
      background-position: center;
      background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)),
      url('<%= cl_image_path @list.photo.key, height: 600, crop: :fill %>')">
    <h1><%= @list.name %></h1>
</div>

<div class="container my-4">
  <div class="row">

    <% if @list.movies.empty? %>

      <div class="col-12">
        <p class="text-center">
          Sorry, you don't have any film in this list yet.
        </p>
      </div>

    <% else %>

      <% @list.bookmarks.each do |bookmark| %>

        <div class="col-12 col-md-6 col-lg-4 mb-4">

          <div class="card h-100 shadow-sm">

            <%= image_tag bookmark.movie.poster_url,
                          alt: bookmark.movie.title,
                          class: "card-img-top",
                          style: "height: 300px; object-fit: cover; object-position: top center;" %>

            <div class="card-body d-flex flex-column">

               <div class="d-flex justify-content-between align-items-center mb-2">
    <h5 class="card-title mb-0" style="font-weight: bold;">
      <%= bookmark.movie.title %>
    </h5>
    <span style="font-size: 14px;">⭐ <%= bookmark.movie.rating %></span>
  </div>

              <p class="card-text"
                 style="font-size: 14px;">
                <strong>Overview:</strong><br>
                <%= bookmark.movie.overview %>
              </p>

              <p class="card-text"
              style="font-size: 14px;">
                <strong>Comment:</strong>
                <%= bookmark.comment %>
              </p>


              <%= link_to "Supprimer",
                          bookmark_path(bookmark),
                          data: {
                            turbo_method: :delete,
                            turbo_confirm: "Are you sure?"
                          },
                          class: "btn button-custom-delete mt-auto" %>

            </div>

          </div>

        </div>

      <% end %>

    <% end %>

  </div>

  <div class="text-center mt-4">
    <%= link_to "Add a movie",
                new_list_bookmark_path(@list),
                class: "btn btn-custom px-4 py-2" %>
  </div>

</div>
